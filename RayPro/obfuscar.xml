<?xml version='1.0'?>
<Obfuscator>

  <Var name="InPath"  value="bin\Release" />
  <Var name="OutPath" value="bin\Release" />

  <Var name="RenameProperties" value="true" />
  <Var name="RenameEvents"     value="true" />
  <Var name="RenameFields"     value="true" />
  <Var name="KeepPublicApi"    value="false" />
  <Var name="HideStrings"      value="true" />
  <Var name="UseUnicodeNames"  value="true" />

  <Module file="$(InPath)\RayPro.exe">

    <!-- FIX #1: No ofuscar el entry point -->
    <SkipType name="RayPro.Program" />

    <!-- FIX #2: No ofuscar Settings (referenciado por nombre en App.config) -->
    <SkipNamespace name="RayPro.configuraciones" />

    <!-- FIX #2: No ofuscar formularios WinForms (Designer los referencia por nombre) -->
    <!-- Formularios en RayPro.Vista -->
    <SkipNamespace name="RayPro.Vista" />
    <!-- Formulario principal (namespace raíz RayPro) -->
    <SkipType name="RayPro.MainRayX" />
    <!-- Formularios en RayPro.Aplicaciones (solo los Forms, NO el subnamespace tools) -->
    <SkipType name="RayPro.Aplicaciones.SettingDev" />
    <SkipType name="RayPro.Aplicaciones.FrKeyBoard" />
    <!-- Control personalizado en namespace legacy -->
    <SkipType name="MamografiaGP.Mamorx.Front.LargeRadioButton" />
    <!-- RayPro.Aplicaciones.tools.* se ofusca completamente (LicenciaManager, LicenciaDatos, AppSession, UsbCdcManager, DatosRadiologia, HumanSupport) -->

    <!-- FIX #3: No ofuscar miembros públicos (necesario para System.Text.Json y serialización) -->
    <SkipMethod  name="*" attrib="public" />
    <SkipProperty name="*" attrib="public" />

    <!-- FIX #3: No ofuscar tipos con atributos de serialización -->
    <SkipType name="*" attrib="serializable" />

  </Module>

</Obfuscator>
